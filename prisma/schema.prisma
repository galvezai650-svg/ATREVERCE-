generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String            @id @default(cuid())
  email     String            @unique
  name      String
  password  String?
  isPremium Boolean           @default(false)
  emailVerified    Boolean           @default(false)
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  subscriptions Subscription[]
  quizScores   QuizScore[]
  missionProgress MissionProgress[]
  communityPosts  CommunityPost[]
  certificates    Certificate[]
  certificationExams CertificationExam[]
}

model Subscription {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  subscriptionId String?
  planId         String   @default("P-2YH58611DA4123336NHODNII")
  status         String   @default("pending") // pending, approved, rejected
  amount         Float    @default(4.99)
  currency       String   @default("USD")
  createdAt      DateTime @default(now())
  reviewedAt     DateTime?
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuizScore {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  score         Int
  correctCount  Int
  totalQuestions Int
  bestStreak    Int      @default(0)
  grade         String   // Maestro del Universo, Científico Espacial, Astronauta, Explorador Novato
  percentage    Int
  createdAt     DateTime @default(now())
}

model MissionProgress {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  missionId String
  completed Boolean  @default(false)
  progress  Int      @default(0) // 0-100
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, missionId])
}

model CommunityPost {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  content   String
  category  String   @default("general") // general, fotos, preguntas, descubrimientos
  likes     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Certificate {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  courseName   String
  certificateId String  @unique
  description  String   @default("")
  createdAt    DateTime @default(now())
}

model CertificationExam {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  courseName      String
  score           Int
  totalQuestions  Int
  correctAnswers  Int
  grade           String
  verificationCode String  @unique
  passed          Boolean
  timeSpent       Int
  createdAt       DateTime @default(now())
}
